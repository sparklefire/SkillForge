# Step Plan。复制为 .env 后填入真实密钥；不要提交 .env。
STEP_API_KEY=
STEP_BASE_URL=https://api.stepfun.com/step_plan/v1
STEP_CHAT_COMPLETIONS_URL=https://api.stepfun.com/step_plan/v1/chat/completions
STEP_MESSAGES_URL=https://api.stepfun.com/step_plan/v1/messages
STEP_ASR_URL=https://api.stepfun.com/step_plan/v1/audio/asr/sse
STEP_MODEL=step-3.7-flash

# 可选：未配置时自动搜索 PATH 和 DGX 用户级安装位置。
SKILLFORGE_FFMPEG_BIN=
SKILLFORGE_FFPROBE_BIN=

# DGX Spark 远程环境。
DGX_SSH_HOST=106.13.186.155
DGX_SSH_PORT=6052
DGX_SSH_USER=Developer
