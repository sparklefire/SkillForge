{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/conflict.schema.json",
  "title": "SkillForge Conflict Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "iteration", "conflicts"],
  "properties": {
    "case_id": {"type": "string", "minLength": 1},
    "iteration": {"type": "integer", "minimum": 1},
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "conflict_id",
          "kind",
          "severity",
          "step_ids",
          "message",
          "evidence",
          "details",
          "proposed_action",
          "automatic",
          "status"
        ],
        "properties": {
          "conflict_id": {"type": "string", "pattern": "^C[0-9]{3}$"},
          "kind": {
            "enum": [
              "MISSING_STEP",
              "MISSING_PREREQUISITE",
              "ORDER_ERROR",
              "UNSUPPORTED_TOOL",
              "UNSUPPORTED_PARAMETER",
              "MISSING_EVIDENCE",
              "INVALID_EVIDENCE"
            ]
          },
          "severity": {"enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
          "step_ids": {
            "type": "array",
            "items": {"type": "string", "pattern": "^S[0-9]{2}$"}
          },
          "message": {"type": "string", "minLength": 1},
          "evidence": {
            "type": "array",
            "items": {
              "$ref": "https://skillforge.local/schemas/evidence.schema.json"
            }
          },
          "details": {"type": "object"},
          "proposed_action": {"enum": ["INSERT", "REORDER", "REMOVE", "REVIEW"]},
          "automatic": {"type": "boolean"},
          "status": {"enum": ["OPEN", "RESOLVED", "NEEDS_REVIEW"]}
        }
      }
    }
  }
}
