{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/pdf_structure_report.schema.json",
  "title": "SkillForge PDF Structure Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "case_id",
    "report_id",
    "generated_at",
    "status",
    "ocr_mode",
    "ocr_configuration",
    "external_model_calls",
    "sources",
    "queries",
    "summary",
    "data_policy"
  ],
  "properties": {
    "version": {"const": 1},
    "case_id": {"type": "string", "minLength": 1},
    "report_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "status": {"enum": ["COMPLETED", "NEEDS_REVIEW"]},
    "ocr_mode": {"enum": ["disabled", "auto", "required"]},
    "ocr_configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["languages", "dpi", "traineddata_sha256"],
      "properties": {
        "languages": {"type": "string", "minLength": 1},
        "dpi": {"type": "integer", "minimum": 72, "maximum": 600},
        "traineddata_sha256": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "external_model_calls": {"const": 0},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source"}
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/query"}
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_count",
        "page_count",
        "character_count",
        "block_count",
        "block_counts_by_kind",
        "needs_ocr_page_count",
        "ocr_applied_page_count",
        "search_chunk_count",
        "query_count",
        "passed_query_count"
      ],
      "properties": {
        "source_count": {"type": "integer", "minimum": 1},
        "page_count": {"type": "integer", "minimum": 1},
        "character_count": {"type": "integer", "minimum": 1},
        "block_count": {"type": "integer", "minimum": 1},
        "block_counts_by_kind": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "needs_ocr_page_count": {"type": "integer", "minimum": 0},
        "ocr_applied_page_count": {"type": "integer", "minimum": 0},
        "search_chunk_count": {"type": "integer", "minimum": 1},
        "query_count": {"type": "integer", "minimum": 1},
        "passed_query_count": {"type": "integer", "minimum": 0}
      }
    },
    "data_policy": {
      "const": {
        "contains_pdf_text": false,
        "contains_page_images": false,
        "contains_credentials": false,
        "contains_absolute_paths": false,
        "external_model_calls": 0,
        "raw_pdf_and_private_index_git_ignored": true
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "input_sha256",
        "rights_status",
        "page_count",
        "character_count",
        "block_count",
        "block_counts_by_kind",
        "needs_ocr_page_count",
        "ocr_applied_page_count",
        "search_chunk_count"
      ],
      "properties": {
        "source_ref": {"type": "string", "minLength": 1},
        "input_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "rights_status": {"type": "string", "minLength": 1},
        "page_count": {"type": "integer", "minimum": 1},
        "character_count": {"type": "integer", "minimum": 0},
        "block_count": {"type": "integer", "minimum": 0},
        "block_counts_by_kind": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "needs_ocr_page_count": {"type": "integer", "minimum": 0},
        "ocr_applied_page_count": {"type": "integer", "minimum": 0},
        "search_chunk_count": {"type": "integer", "minimum": 0}
      }
    },
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_id",
        "query",
        "status",
        "hit_count",
        "exact_match_count",
        "top_hits"
      ],
      "properties": {
        "query_id": {"type": "string", "pattern": "^Q[0-9]{2}$"},
        "query": {"type": "string", "minLength": 1},
        "status": {"enum": ["PASSED", "FAILED"]},
        "hit_count": {"type": "integer", "minimum": 0},
        "exact_match_count": {"type": "integer", "minimum": 0},
        "top_hits": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_ref",
              "page",
              "block_id",
              "kind",
              "score",
              "exact_match"
            ],
            "properties": {
              "source_ref": {"type": "string", "minLength": 1},
              "page": {"type": "integer", "minimum": 1},
              "block_id": {"type": "string", "pattern": "^P[0-9]{4}-B[0-9]{3}$"},
              "kind": {
                "enum": ["HEADING", "PARAGRAPH", "LIST_ITEM", "WARNING", "TABLE", "CAPTION"]
              },
              "score": {"type": "number", "minimum": 0},
              "exact_match": {"type": "boolean"}
            }
          }
        }
      }
    }
  }
}
