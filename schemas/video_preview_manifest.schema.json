{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/video_preview_manifest.schema.json",
  "title": "SkillForge Video Preview Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "version",
    "case_id",
    "generated_at",
    "status",
    "output_profile_sha256",
    "profile",
    "summary",
    "items",
    "data_policy"
  ],
  "properties": {
    "artifact_type": {"const": "VIDEO_PREVIEW_MANIFEST"},
    "version": {"const": 1},
    "case_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "status": {"const": "COMPLETED"},
    "output_profile_sha256": {"$ref": "#/$defs/sha256"},
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_width",
        "max_height",
        "fps",
        "video_codec",
        "target_video_kbps",
        "audio_codec",
        "audio_kbps",
        "max_total_kbps",
        "faststart"
      ],
      "properties": {
        "max_width": {"type": "integer", "minimum": 320, "maximum": 1280},
        "max_height": {"type": "integer", "minimum": 180, "maximum": 720},
        "fps": {"type": "integer", "minimum": 5, "maximum": 24},
        "video_codec": {"const": "h264"},
        "target_video_kbps": {"type": "integer", "minimum": 100, "maximum": 1000},
        "audio_codec": {"const": "aac"},
        "audio_kbps": {"type": "integer", "minimum": 24, "maximum": 128},
        "max_total_kbps": {"type": "integer", "minimum": 150, "maximum": 1200},
        "faststart": {"const": true}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_count",
        "source_duration_ms",
        "preview_duration_ms",
        "preview_bytes",
        "max_average_total_bitrate_kbps",
        "all_checks_passed"
      ],
      "properties": {
        "source_count": {"type": "integer", "minimum": 1},
        "source_duration_ms": {"type": "integer", "minimum": 1},
        "preview_duration_ms": {"type": "integer", "minimum": 1},
        "preview_bytes": {"type": "integer", "minimum": 1},
        "max_average_total_bitrate_kbps": {"type": "number", "minimum": 0},
        "all_checks_passed": {"const": true}
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "source_role",
          "source_privacy_status",
          "source_sha256",
          "source_duration_ms",
          "preview_file",
          "preview_sha256",
          "preview_bytes",
          "preview_duration_ms",
          "duration_delta_ms",
          "width",
          "height",
          "fps",
          "video_codec",
          "audio_codec",
          "average_total_bitrate_kbps",
          "timeline_mapping",
          "checks"
        ],
        "properties": {
          "source_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
          "source_role": {"type": "string", "minLength": 1},
          "source_privacy_status": {"const": "LOCAL_QA_PASSED"},
          "source_sha256": {"$ref": "#/$defs/sha256"},
          "source_duration_ms": {"type": "integer", "minimum": 1},
          "preview_file": {"type": "string", "pattern": "^[A-Z0-9_]+\\.mp4$"},
          "preview_sha256": {"$ref": "#/$defs/sha256"},
          "preview_bytes": {"type": "integer", "minimum": 1},
          "preview_duration_ms": {"type": "integer", "minimum": 1},
          "duration_delta_ms": {"type": "integer", "minimum": 0, "maximum": 250},
          "width": {"type": "integer", "minimum": 2},
          "height": {"type": "integer", "minimum": 2},
          "fps": {"type": "number", "exclusiveMinimum": 0},
          "video_codec": {"const": "h264"},
          "audio_codec": {"type": ["string", "null"]},
          "average_total_bitrate_kbps": {"type": "number", "minimum": 0},
          "timeline_mapping": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source_start_ms", "source_end_ms", "preview_start_ms", "preview_end_ms"],
              "properties": {
                "source_start_ms": {"type": "integer", "minimum": 0},
                "source_end_ms": {"type": "integer", "minimum": 1},
                "preview_start_ms": {"type": "integer", "minimum": 0},
                "preview_end_ms": {"type": "integer", "minimum": 1}
              }
            }
          },
          "checks": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "duration_preserved",
              "dimensions_within_profile",
              "fps_within_profile",
              "codec_matches_profile",
              "bitrate_within_profile",
              "faststart"
            ],
            "properties": {
              "duration_preserved": {"const": true},
              "dimensions_within_profile": {"const": true},
              "fps_within_profile": {"const": true},
              "codec_matches_profile": {"const": true},
              "bitrate_within_profile": {"const": true},
              "faststart": {"const": true}
            }
          }
        }
      }
    },
    "data_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage_scope",
        "external_model_calls",
        "contains_raw_media",
        "contains_preview_media",
        "contains_credentials",
        "contains_absolute_paths"
      ],
      "properties": {
        "storage_scope": {"const": "LOCAL_PRIVATE_DERIVATIVE"},
        "external_model_calls": {"const": 0},
        "contains_raw_media": {"const": false},
        "contains_preview_media": {"const": false},
        "contains_credentials": {"const": false},
        "contains_absolute_paths": {"const": false}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
