{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/submission_article_qa.schema.json",
  "title": "SkillForge Submission Article QA",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "case_id",
    "artifact_type",
    "status",
    "article_path",
    "article_sha256",
    "article_bytes",
    "chinese_character_count",
    "heading_count",
    "repository_link_count",
    "source_checks",
    "claim_checks",
    "checks",
    "publication_state",
    "data_policy"
  ],
  "properties": {
    "version": {"const": 1},
    "case_id": {"const": "n31_media_change"},
    "artifact_type": {"const": "SUBMISSION_ARTICLE_QA"},
    "status": {"const": "READY_FOR_MANUAL_PUBLICATION"},
    "article_path": {"const": "docs/赛事征文.md"},
    "article_sha256": {"$ref": "#/$defs/sha256"},
    "article_bytes": {"type": "integer", "minimum": 1},
    "chinese_character_count": {"type": "integer", "minimum": 600},
    "heading_count": {"const": 9},
    "repository_link_count": {"type": "integer", "minimum": 8},
    "source_checks": {
      "type": "array",
      "minItems": 17,
      "maxItems": 17,
      "items": {"$ref": "#/$defs/sourceCheck"}
    },
    "claim_checks": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {"$ref": "#/$defs/claimCheck"}
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title_present",
        "minimum_length_met",
        "required_headings_exact",
        "required_headings_ordered",
        "required_claims_source_backed",
        "repository_links_safe",
        "repository_links_resolve",
        "forbidden_phrases_absent",
        "absolute_paths_absent",
        "credentials_absent",
        "private_submission_state_absent",
        "manual_publication_only"
      ],
      "properties": {
        "title_present": {"const": true},
        "minimum_length_met": {"const": true},
        "required_headings_exact": {"const": true},
        "required_headings_ordered": {"const": true},
        "required_claims_source_backed": {"const": true},
        "repository_links_safe": {"const": true},
        "repository_links_resolve": {"const": true},
        "forbidden_phrases_absent": {"const": true},
        "absolute_paths_absent": {"const": true},
        "credentials_absent": {"const": true},
        "private_submission_state_absent": {"const": true},
        "manual_publication_only": {"const": true}
      }
    },
    "publication_state": {
      "const": {
        "article_content_ready": true,
        "public_url_available": false,
        "manual_publication_required": true,
        "automatic_publication_performed": false
      }
    },
    "data_policy": {
      "const": {
        "contains_credentials": false,
        "contains_personal_data": false,
        "contains_form_url": false,
        "contains_absolute_paths": false,
        "contains_private_submission_state": false,
        "contains_raw_media": false,
        "network_requests": 0
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "sourceCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "path", "sha256", "status"],
      "properties": {
        "source_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
        "path": {"type": "string", "pattern": "^(cases|config|external|output)/"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "status": {"const": "PASSED"}
      }
    },
    "claimCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "source_ids", "fact_sha256", "status"],
      "properties": {
        "claim_id": {
          "enum": [
            "TRACEABLE_REVISION_LOOP",
            "GOLD_13_STEPS",
            "ERRORS_5_TO_0",
            "COVERAGE_90_TO_100",
            "FOUR_LOCAL_REVISIONS",
            "TRAINING_OUTPUTS",
            "DGX_NATIVE_CUDA",
            "PDF_STRUCTURE",
            "MULTISOURCE_ABLATION",
            "SOURCE_CANDIDATE_SYNTHESIS",
            "AGENT_TOOL_TRACE",
            "SELECTIVE_REBUILD",
            "RUNTIME_SCOPE",
            "MODEL_AND_REFERENCE_BOUNDARY",
            "DEMO_MODES"
          ]
        },
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}
        },
        "fact_sha256": {"$ref": "#/$defs/sha256"},
        "status": {"const": "PASSED"}
      }
    }
  }
}
