{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/submission_closeout_status.schema.json",
  "title": "SkillForge Submission Closeout Status",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "case_id",
    "artifact_type",
    "generated_at",
    "status",
    "implementation_goal_blocked",
    "formal_submission_ready",
    "submission_archived",
    "stage_count",
    "completed_stage_count",
    "human_gate_summary",
    "next_action",
    "stages",
    "data_policy"
  ],
  "properties": {
    "version": {"const": 1},
    "case_id": {"const": "n31_media_change"},
    "artifact_type": {"const": "SUBMISSION_CLOSEOUT_STATUS"},
    "generated_at": {"type": "string", "format": "date-time"},
    "status": {
      "enum": [
        "TECHNICAL_PACKAGE_PENDING",
        "TECHNICAL_READY_HUMAN_GATES_PENDING",
        "FINAL_PREFLIGHT_PENDING",
        "READY_FOR_UPLOAD",
        "PUBLIC_LINK_QA_PENDING",
        "SUBMISSION_RECEIPT_PENDING",
        "READY_FOR_ARCHIVE",
        "NEEDS_REVIEW"
      ]
    },
    "implementation_goal_blocked": {"const": false},
    "formal_submission_ready": {"type": "boolean"},
    "submission_archived": {"type": "boolean"},
    "stage_count": {"const": 10},
    "completed_stage_count": {"type": "integer", "minimum": 0, "maximum": 10},
    "human_gate_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmed", "pending", "total", "store_state", "valid", "issue_count"],
      "properties": {
        "confirmed": {"type": "integer", "minimum": 0, "maximum": 5},
        "pending": {"type": "integer", "minimum": 0, "maximum": 5},
        "total": {"const": 5},
        "store_state": {"enum": ["ABSENT", "VALID", "INVALID", "STALE"]},
        "valid": {"type": "boolean"},
        "issue_count": {"type": "integer", "minimum": 0}
      }
    },
    "next_action": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["stage_id", "action", "command"],
          "properties": {
            "stage_id": {"$ref": "#/$defs/stageId"},
            "action": {"type": "string", "minLength": 1, "maxLength": 300},
            "command": {"type": ["string", "null"], "maxLength": 300}
          }
        }
      ]
    },
    "stages": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {"$ref": "#/$defs/stage"}
    },
    "data_policy": {
      "const": {
        "private_local_state": true,
        "contains_credentials": false,
        "contains_personal_data": false,
        "contains_urls": false,
        "contains_evidence_paths": false,
        "contains_private_notes": false,
        "contains_raw_media": false,
        "automatic_human_confirmations": 0,
        "network_requests": 0
      }
    }
  },
  "$defs": {
    "stageId": {
      "enum": [
        "TECHNICAL_RELEASE_BUNDLE",
        "TRAINING_VIDEO_FULL_WATCH",
        "TEAM_ELIGIBILITY_CONFIRMED",
        "OFFICIAL_RULES_VERIFIED",
        "FINAL_STAGE_REHEARSAL",
        "FINAL_RECORDING_REVIEW",
        "FINAL_CLEAN_PREFLIGHT",
        "SUBMISSION_UPLOAD",
        "PUBLIC_LINK_QA",
        "SUBMISSION_RECEIPT"
      ]
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "category",
        "status",
        "evidence_state",
        "human_gate_id",
        "depends_on",
        "next_action",
        "next_command"
      ],
      "properties": {
        "stage_id": {"$ref": "#/$defs/stageId"},
        "category": {"enum": ["TECHNICAL", "HUMAN", "EXTERNAL", "SUBMISSION"]},
        "status": {
          "enum": [
            "COMPLETED",
            "READY",
            "READY_FOR_CONFIRMATION",
            "AWAITING_HUMAN",
            "AWAITING_EXTERNAL",
            "WAITING_ON_DEPENDENCIES",
            "NEEDS_REVIEW"
          ]
        },
        "evidence_state": {
          "enum": [
            "ABSENT",
            "DRAFT",
            "INPUT_READY",
            "MACHINE_READY",
            "CONFIRMED",
            "VERIFIED",
            "PARTIAL",
            "INVALID",
            "NOT_APPLICABLE"
          ]
        },
        "human_gate_id": {
          "anyOf": [{"type": "null"}, {"type": "string", "pattern": "^[A-Z0-9_]+$"}]
        },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/stageId"}
        },
        "next_action": {"type": ["string", "null"], "maxLength": 300},
        "next_command": {"type": ["string", "null"], "maxLength": 300}
      }
    }
  }
}
