{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/evidence.schema.json",
  "title": "SkillForge Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "source_type",
    "source_ref",
    "claim",
    "locator",
    "classification",
    "relevance",
    "confidence",
    "review_status"
  ],
  "properties": {
    "evidence_id": {"type": "string", "pattern": "^E[0-9]{3}$"},
    "source_type": {"enum": ["pdf", "video", "audio"]},
    "source_ref": {"type": "string", "minLength": 1},
    "claim": {"type": "string", "minLength": 1},
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "page": {"type": "integer", "minimum": 1},
        "paragraph": {"type": "string", "minLength": 1},
        "start_ms": {"type": "integer", "minimum": 0},
        "end_ms": {"type": "integer", "minimum": 0},
        "keyframe": {"type": "string", "minLength": 1}
      },
      "anyOf": [
        {"required": ["page"]},
        {"required": ["start_ms", "end_ms"]}
      ]
    },
    "classification": {
      "enum": ["SOURCE_FACT", "EXPERT_ADVICE", "MODEL_INFERENCE"]
    },
    "relevance": {"type": "number", "minimum": 0, "maximum": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "review_status": {"enum": ["UNREVIEWED", "VERIFIED", "REJECTED"]}
  }
}
