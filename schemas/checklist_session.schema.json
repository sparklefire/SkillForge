{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/checklist_session.schema.json",
  "title": "SkillForge Checklist Session",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type", "version", "session_id", "case_id", "sop_version", "created_at", "updated_at", "status", "progress", "items", "completion_log", "feedback_log"],
  "properties": {
    "artifact_type": {"const": "CHECKLIST_SESSION"},
    "version": {"const": 1},
    "session_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
    "case_id": {"type": "string", "minLength": 1},
    "sop_version": {"type": "integer", "minimum": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "status": {"enum": ["NOT_STARTED", "IN_PROGRESS", "COMPLETED"]},
    "progress": {
      "type": "object", "additionalProperties": false,
      "required": ["total_items", "completed_items"],
      "properties": {
        "total_items": {"type": "integer", "minimum": 8, "maximum": 15},
        "completed_items": {"type": "integer", "minimum": 0, "maximum": 15}
      }
    },
    "items": {
      "type": "array", "minItems": 8, "maxItems": 15,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["item_id", "step_id", "title", "completed"],
        "properties": {
          "item_id": {"type": "string", "pattern": "^CL[0-9]{2}$"},
          "step_id": {"type": "string", "pattern": "^S[0-9]{2}$"},
          "title": {"type": "string", "minLength": 1},
          "completed": {"type": "boolean"}
        }
      }
    },
    "completion_log": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["event_id", "step_id", "action", "recorded_at"],
        "properties": {
          "event_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
          "step_id": {"type": "string", "pattern": "^S[0-9]{2}$"},
          "action": {"enum": ["COMPLETED", "REOPENED"]},
          "recorded_at": {"type": "string", "format": "date-time"}
        }
      }
    },
    "feedback_log": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["feedback_id", "step_id", "category", "comment", "recorded_at"],
        "properties": {
          "feedback_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
          "step_id": {"type": "string", "pattern": "^S[0-9]{2}$"},
          "category": {"enum": ["CONTENT_ERROR", "EVIDENCE_ISSUE", "STEP_BLOCKED", "OTHER"]},
          "comment": {"type": "string", "minLength": 1, "maxLength": 500},
          "recorded_at": {"type": "string", "format": "date-time"}
        }
      }
    }
  }
}
