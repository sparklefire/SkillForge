{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/source_candidate_synthesis.schema.json",
  "title": "SkillForge Source Candidate Synthesis Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "case_id",
    "report_id",
    "status",
    "extraction_mode",
    "uses_gold_step_text",
    "source_candidates",
    "source_observations",
    "merge_groups",
    "ordered_steps",
    "phase_applicability",
    "summary",
    "data_policy"
  ],
  "properties": {
    "version": {"const": 1},
    "case_id": {"type": "string", "minLength": 1},
    "report_id": {"const": "SOURCE_CANDIDATE_SYNTHESIS_V1"},
    "status": {"enum": ["COMPLETED", "NEEDS_REVIEW"]},
    "extraction_mode": {
      "enum": ["MODEL_EXTRACTED", "REVIEWED_SOURCE_PROJECTION"]
    },
    "uses_gold_step_text": {"const": false},
    "source_candidates": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "source_candidate_plan.schema.json#/$defs/candidate"}
    },
    "source_observations": {
      "type": "array",
      "items": {"$ref": "source_candidate_plan.schema.json#/$defs/negativeObservation"}
    },
    "merge_groups": {
      "type": "array",
      "minItems": 8,
      "maxItems": 15,
      "items": {"$ref": "#/$defs/mergeGroup"}
    },
    "ordered_steps": {
      "type": "array",
      "minItems": 8,
      "maxItems": 15,
      "items": {"$ref": "#/$defs/orderedStep"}
    },
    "phase_applicability": {
      "$ref": "source_candidate_plan.schema.json#/properties/phase_applicability"
    },
    "summary": {"$ref": "#/$defs/summary"},
    "data_policy": {
      "const": {
        "contains_credentials": false,
        "contains_raw_media": false,
        "contains_absolute_paths": false,
        "external_model_calls": 0
      }
    }
  },
  "$defs": {
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "target_step_id", "action", "evidence_ids"],
      "properties": {
        "mode": {
          "enum": ["NOT_REQUIRED", "RETRY_CURRENT", "RETURN_TO_STEP", "STOP_AND_REVIEW"]
        },
        "target_step_id": {
          "anyOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^S[0-9]{2}$"}
          ]
        },
        "action": {"type": "string", "minLength": 1},
        "evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^E[0-9]{3}$"}
        }
      }
    },
    "mergeGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "semantic_key",
        "step_id",
        "phase",
        "operations",
        "candidate_ids",
        "candidate_part_ids",
        "source_types",
        "evidence_ids",
        "rationale"
      ],
      "properties": {
        "group_id": {"type": "string", "pattern": "^MG[0-9]{2}$"},
        "semantic_key": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
        "step_id": {"type": "string", "pattern": "^S[0-9]{2}$"},
        "phase": {
          "enum": ["PREPARATION", "EXECUTION", "VERIFICATION", "RESET"]
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["KEEP", "SYNONYM_MERGE", "FINE_GRAIN_MERGE", "COARSE_SPLIT"]
          }
        },
        "candidate_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^SC[0-9]{3}$"}
        },
        "candidate_part_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^SC[0-9]{3}-P[0-9]{2}$"}
        },
        "source_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["video", "pdf", "audio"]}
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^E[0-9]{3}$"}
        },
        "rationale": {"type": "string", "minLength": 1}
      }
    },
    "orderedStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "semantic_key",
        "title",
        "action",
        "object",
        "phase",
        "prerequisites",
        "tools",
        "parameters",
        "warnings",
        "success_check",
        "required",
        "irreversible",
        "recovery",
        "candidate_ids",
        "source_types",
        "evidence_ids",
        "confidence",
        "confidence_assessment",
        "status"
      ],
      "properties": {
        "step_id": {"type": "string", "pattern": "^S[0-9]{2}$"},
        "semantic_key": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
        "title": {"type": "string", "minLength": 1},
        "action": {"type": "string", "minLength": 1},
        "object": {"type": "string", "minLength": 1},
        "phase": {
          "enum": ["PREPARATION", "EXECUTION", "VERIFICATION", "RESET"]
        },
        "prerequisites": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^S[0-9]{2}$"}
        },
        "tools": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "parameters": {
          "type": "array",
          "items": {"$ref": "sop.schema.json#/$defs/parameter"}
        },
        "warnings": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "success_check": {"type": "string", "minLength": 1},
        "required": {"type": "boolean"},
        "irreversible": {"type": "boolean"},
        "recovery": {"$ref": "#/$defs/recovery"},
        "candidate_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^SC[0-9]{3}$"}
        },
        "source_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["video", "pdf", "audio"]}
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^E[0-9]{3}$"}
        },
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "confidence_assessment": {"$ref": "#/$defs/confidenceAssessment"},
        "status": {"enum": ["NEEDS_REVIEW", "VERIFIED"]}
      }
    },
    "sourceComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "candidate_id",
        "classifications",
        "authority_weight",
        "best_candidate_confidence",
        "support_factor",
        "review_factor",
        "adjusted_confidence"
      ],
      "properties": {
        "source_type": {"enum": ["video", "pdf", "audio"]},
        "candidate_id": {"type": "string", "pattern": "^SC[0-9]{3}$"},
        "classifications": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["SOURCE_FACT", "EXPERT_ADVICE", "MODEL_INFERENCE"]}
        },
        "authority_weight": {"type": "number", "minimum": 0, "maximum": 1},
        "best_candidate_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "support_factor": {"type": "number", "minimum": 0, "maximum": 1},
        "review_factor": {"type": "number", "minimum": 0, "maximum": 1},
        "adjusted_confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "confidenceAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "band",
        "source_components",
        "corroboration_bonus",
        "observation_penalty",
        "observation_ids",
        "route",
        "rationale"
      ],
      "properties": {
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "band": {"enum": ["HIGH", "MEDIUM", "LOW"]},
        "source_components": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {"$ref": "#/$defs/sourceComponent"}
        },
        "corroboration_bonus": {"type": "number", "minimum": 0, "maximum": 0.08},
        "observation_penalty": {"type": "number", "minimum": 0, "maximum": 0.5},
        "observation_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^NO[0-9]{3}$"}
        },
        "route": {
          "enum": ["AUTO_VERIFY", "VERIFIER_QUEUE", "HUMAN_REVIEW_REQUIRED"]
        },
        "rationale": {"type": "string", "minLength": 1}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_candidate_count",
        "source_candidate_counts",
        "deduplicated_candidate_ids",
        "ordered_step_count",
        "phase_counts",
        "coarse_candidate_count",
        "coarse_fragment_count",
        "fine_candidate_count",
        "coarse_split_group_count",
        "fine_merge_group_count",
        "synonym_merge_group_count",
        "multi_source_step_count",
        "three_source_step_count",
        "irreversible_step_ids",
        "recovery_step_count",
        "confidence_band_counts",
        "review_route_counts",
        "conflicted_step_ids",
        "low_confidence_step_ids",
        "all_steps_evidence_grounded",
        "graph_acyclic"
      ],
      "properties": {
        "source_candidate_count": {"type": "integer", "minimum": 3},
        "source_candidate_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["video", "pdf", "audio"],
          "properties": {
            "video": {"type": "integer", "minimum": 1},
            "pdf": {"type": "integer", "minimum": 1},
            "audio": {"type": "integer", "minimum": 1}
          }
        },
        "deduplicated_candidate_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^SC[0-9]{3}$"}
        },
        "ordered_step_count": {"type": "integer", "minimum": 8, "maximum": 15},
        "phase_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["PREPARATION", "EXECUTION", "VERIFICATION", "RESET"],
          "properties": {
            "PREPARATION": {"type": "integer", "minimum": 0},
            "EXECUTION": {"type": "integer", "minimum": 0},
            "VERIFICATION": {"type": "integer", "minimum": 0},
            "RESET": {"type": "integer", "minimum": 0}
          }
        },
        "coarse_candidate_count": {"type": "integer", "minimum": 0},
        "coarse_fragment_count": {"type": "integer", "minimum": 0},
        "fine_candidate_count": {"type": "integer", "minimum": 0},
        "coarse_split_group_count": {"type": "integer", "minimum": 0},
        "fine_merge_group_count": {"type": "integer", "minimum": 0},
        "synonym_merge_group_count": {"type": "integer", "minimum": 0},
        "multi_source_step_count": {"type": "integer", "minimum": 0},
        "three_source_step_count": {"type": "integer", "minimum": 0},
        "irreversible_step_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^S[0-9]{2}$"}
        },
        "recovery_step_count": {"type": "integer", "minimum": 0},
        "confidence_band_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["HIGH", "MEDIUM", "LOW"],
          "properties": {
            "HIGH": {"type": "integer", "minimum": 0},
            "MEDIUM": {"type": "integer", "minimum": 0},
            "LOW": {"type": "integer", "minimum": 0}
          }
        },
        "review_route_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["AUTO_VERIFY", "VERIFIER_QUEUE", "HUMAN_REVIEW_REQUIRED"],
          "properties": {
            "AUTO_VERIFY": {"type": "integer", "minimum": 0},
            "VERIFIER_QUEUE": {"type": "integer", "minimum": 0},
            "HUMAN_REVIEW_REQUIRED": {"type": "integer", "minimum": 0}
          }
        },
        "conflicted_step_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^S[0-9]{2}$"}
        },
        "low_confidence_step_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^S[0-9]{2}$"}
        },
        "all_steps_evidence_grounded": {"const": true},
        "graph_acyclic": {"const": true}
      }
    }
  }
}
