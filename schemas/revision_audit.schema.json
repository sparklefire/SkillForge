{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/revision_audit.schema.json",
  "title": "SkillForge Revision Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "iteration",
    "started_at",
    "completed_at",
    "before_digest",
    "after_digest",
    "changes"
  ],
  "properties": {
    "case_id": {"type": "string", "minLength": 1},
    "iteration": {"type": "integer", "minimum": 1, "maximum": 3},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "before_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "after_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["conflict_id", "action", "path", "before", "after", "reason", "evidence_ids"],
        "properties": {
          "conflict_id": {"type": "string", "pattern": "^C[0-9]{3}$"},
          "action": {"enum": ["INSERT", "REORDER", "REMOVE", "REPLACE"]},
          "path": {"type": "string", "minLength": 1},
          "before": {},
          "after": {},
          "reason": {"type": "string", "minLength": 1},
          "evidence_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^E[0-9]{3}$"}
          }
        }
      }
    }
  }
}
