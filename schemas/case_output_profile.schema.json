{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillforge.local/schemas/case_output_profile.schema.json",
  "title": "SkillForge Case Output Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "version",
    "case_id",
    "audience",
    "language",
    "duration",
    "output_types",
    "preview_profile",
    "data_policy"
  ],
  "properties": {
    "artifact_type": {"const": "CASE_OUTPUT_PROFILE"},
    "version": {"const": 1},
    "case_id": {"type": "string", "minLength": 1},
    "audience": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_role", "experience_level", "usage_context"],
      "properties": {
        "primary_role": {"enum": ["NEW_OPERATOR", "EXPERIENCED_OPERATOR", "TRAINER"]},
        "experience_level": {"enum": ["BEGINNER", "INTERMEDIATE", "ADVANCED"]},
        "usage_context": {"enum": ["ON_DEVICE_TASK_SUPPORT", "CLASSROOM_TRAINING", "SELF_STUDY"]}
      }
    },
    "language": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locale", "content_language", "narration_language", "terminology_policy"],
      "properties": {
        "locale": {"type": "string", "pattern": "^[a-z]{2}-[A-Z]{2}$"},
        "content_language": {"enum": ["SIMPLIFIED_CHINESE", "TRADITIONAL_CHINESE", "ENGLISH"]},
        "narration_language": {"enum": ["MANDARIN", "CANTONESE", "ENGLISH"]},
        "terminology_policy": {"enum": ["DEVICE_MANUAL_AND_OPERATOR_VERIFIED"]}
      }
    },
    "duration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_video_min_seconds",
        "source_video_max_seconds",
        "training_video_min_seconds",
        "training_video_target_seconds",
        "training_video_max_seconds"
      ],
      "properties": {
        "source_video_min_seconds": {"type": "integer", "minimum": 1},
        "source_video_max_seconds": {"type": "integer", "minimum": 1},
        "training_video_min_seconds": {"type": "integer", "minimum": 1},
        "training_video_target_seconds": {"type": "integer", "minimum": 1},
        "training_video_max_seconds": {"type": "integer", "minimum": 1}
      }
    },
    "output_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["output_type", "format", "required"],
        "properties": {
          "output_type": {
            "enum": [
              "STRUCTURED_SOP",
              "MOBILE_CHECKLIST",
              "TRAINING_QUIZ",
              "A4_POSTER",
              "TRAINING_VIDEO",
              "REVISION_AUDIT"
            ]
          },
          "format": {"enum": ["JSON", "PDF", "MP4"]},
          "required": {"type": "boolean"}
        }
      }
    },
    "preview_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_width",
        "max_height",
        "fps",
        "video_codec",
        "target_video_kbps",
        "audio_codec",
        "audio_kbps",
        "max_total_kbps",
        "faststart",
        "accepted_privacy_status"
      ],
      "properties": {
        "max_width": {"type": "integer", "minimum": 320, "maximum": 1280},
        "max_height": {"type": "integer", "minimum": 180, "maximum": 720},
        "fps": {"type": "integer", "minimum": 5, "maximum": 24},
        "video_codec": {"const": "h264"},
        "target_video_kbps": {"type": "integer", "minimum": 100, "maximum": 1000},
        "audio_codec": {"const": "aac"},
        "audio_kbps": {"type": "integer", "minimum": 24, "maximum": 128},
        "max_total_kbps": {"type": "integer", "minimum": 150, "maximum": 1200},
        "faststart": {"const": true},
        "accepted_privacy_status": {"const": "LOCAL_QA_PASSED"}
      }
    },
    "data_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage_scope",
        "external_model_calls",
        "third_party_sources_allowed",
        "contains_credentials",
        "contains_absolute_paths"
      ],
      "properties": {
        "storage_scope": {"const": "LOCAL_PRIVATE_DERIVATIVE"},
        "external_model_calls": {"const": 0},
        "third_party_sources_allowed": {"const": false},
        "contains_credentials": {"const": false},
        "contains_absolute_paths": {"const": false}
      }
    }
  }
}
